{
  // Elite blueprint: elite.artillery_fungus
  id: 'elite.artillery_fungus',
  type: 'elite',
  baseEnemyId: 'enemy.fungal_parasite',  // Base enemy to enhance
  
  // Elite stat multipliers (applied to base enemy stats)
  multipliers: {
    hp: 4.0,          // 4x health (30 -> 120)
    damage: 2.5,      // 2.5x damage (6 -> 15)
    speed: 0.75,      // 75% speed (40 -> 30) - artillery is stationary
    size: 1.4,        // 40% larger (16 -> 22)
    armor: 3,         // +3 armor (0 -> 3)
    xp: 3.7,          // 3.7x XP (6 -> 22)
  },
  
  // Elite specific stats (override base if needed)
  stats: {
    hp: 120,
    damage: 15,
    speed: 30,
    size: 22,
    armor: 3,
    xp: 22,
  },
  
  // Elite mechanics enhancements
  mechanics: {
    movementType: 'artillery_position',
    contactDamage: 10,
    aggroRange: 350,
    wanderRadius: 20,        // Minimal movement - artillery stays positioned
    dropChance: 1.0,
    healthDropChance: 0.22,
    
    // Elite-specific mechanics
    artillery: {
      enabled: true,
      attackType: 'mortar',
      projectileType: 'projectile.spore_mortar',
      attackRange: 300,
      attackInterval: 1800,    // 1.8 seconds between volleys
      
      // Volley configuration
      projectileCount: 3,       // 3 mortars per volley
      projectileSpread: 45,     // 45 degree spread
      volleyPattern: 'arc',     // Arc pattern
      
      // AOE configuration
      aoeRadius: 60,
      aoeDamage: 8,
      aoeDoT: {
        enabled: true,
        damage: 2,
        duration: 3000,
        tickInterval: 500,
      },
      
      // Warning indicators
      showTargeting: true,      // Shows where mortars will land
      warningTime: 800,         // 0.8 second warning
    },
    
    // Critical hits
    critical: {
      chance: 0.25,             // 25% crit chance
      multiplier: 2.0,          // 2x damage on crit
      aoeOnCrit: true,          // Larger explosion on crit
    },
    
    // Piercing shots
    piercing: {
      enabled: true,
      maxTargets: 2,            // Can hit 2 enemies
      damageReduction: 0.7,     // 70% damage to second target
    },
    
    // Siege mode
    siegeMode: {
      enabled: true,
      activateAt: 0.5,          // At 50% HP
      bonusRange: 50,           // +50 range in siege mode
      bonusDamage: 1.3,         // 30% more damage
      reducedMovement: 0.5,     // 50% movement speed
    },
  },
  
  // Elite visual configuration
  graphics: {
    sprite: 'elite_artillery_fungus',
    tint: 0x795548,             // Brown fungus tint
    scale: 1.4,                 // Larger than normal
    glowEffect: true,           // Elite glow
    animation: {
      idle: 'elite_artillery_idle',
      move: 'elite_artillery_move',
      attack: 'elite_artillery_fire',
      reload: 'elite_artillery_reload'
    },
    eliteIndicator: {
      type: 'crosshair',        // Crosshair icon for artillery
      color: 0x795548,          // Brown color
      scale: 1.0,
    },
    // Targeting laser
    targetingLaser: {
      enabled: true,
      color: 0xFF0000,
      width: 2,
      alpha: 0.5,
    }
  },
  
  // Elite AI behavior
  ai: {
    behavior: 'elite_artillery',
    params: {
      aggroRange: 350,
      movePattern: 'find_vantage',    // Finds good position
      targetPriority: 'farthest',     // Targets distant enemies first
      
      // Elite AI features
      predictiveTargeting: true,       // Predicts enemy movement
      leadShots: true,                 // Leads targets
      suppressiveFire: true,           // Area denial
      
      volleyCoordination: true,        // Coordinates with other artillery
      focusFire: true,                 // Can focus fire with allies
      
      repositioning: {
        enabled: true,
        threshold: 3,                  // After 3 volleys
        searchRadius: 100,             // Look for new position
      },
      
      callForHelp: true,               // Calls for protection
      priorityTarget: 'player',        // Always prioritizes player
    }
  },
  
  // Elite loot table
  lootTable: 'lootTable.elite.tier2',
  
  // Elite VFX
  vfx: {
    spawn: 'elite.special',
    hit: 'enemy.hit',
    death: 'elite.special',
    shoot: 'enemy.shoot',
  },
  
  // Elite SFX
  sfx: {
    spawn: 'sound/npc_spawn.mp3',
    hit: 'sound/hit_hard.mp3',
    death: 'sound/elite_death.mp3',
    shoot: 'sound/elite_shoot.mp3',
  },
  
  // Display configuration
  display: {
    key: 'elite.artillery_fungus.name',
    descKey: 'elite.artillery_fungus.desc',
    templates: {
      short: 'Elite Artillery • {{stats.hp}} HP • dosah {{mechanics.artillery.attackRange}} • AOE {{mechanics.artillery.aoeRadius}}',
      desc: 'Elitní dělostřelecká houba s {{stats.hp}} HP. Střílí {{mechanics.artillery.projectileCount}} výbušné spory na vzdálenost {{mechanics.artillery.attackRange}} s AOE {{mechanics.artillery.aoeRadius}} a DoT efektem.',
    },
    namePrefix: 'Elitní',
    nameSuffix: 'Dělostřelec',
    color: '#795548',
    rarity: 'elite',
    icon: 'elite.artillery_fungus',
    category: 'elite',
    sortOrder: 530,
    tags: [
      'elite',
      'artillery',
      'ranged',
      'aoe',
      'fungus',
      'explosive',
      'siege',
      'dot',
    ],
    devNameFallback: 'Elitní dělostřelecká houba',
    devDescFallback: 'Elitní houba střílející výbušné spory s AOE a DoT efektem',
  },
  
  // Elite spawn configuration
  spawnConditions: {
    minLevel: 3,           // Appears from level 3
    minGameTime: 60000,    // After 60 seconds
    maxCount: 2,           // Max 2 at once (powerful artillery)
    cooldown: 25000,       // 25 second cooldown between spawns
    weight: 0.06,          // 6% spawn chance when eligible (rare)
  }
