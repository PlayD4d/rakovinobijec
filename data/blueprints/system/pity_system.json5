{
  id: 'system.pity',
  type: 'powerup',
  version: '1.0.0',
  pityRules: {
    xp_drops: {
      enabled: true,
      maxDryStreak: 8,
      guaranteedDrop: 'drop.xp.small',
      resetOnDrop: [
        'drop.xp.small',
        'drop.xp.medium',
        'drop.xp.large',
      ],
      description: 'Guarantees XP drop every 8 kills maximum',
    },
    health_drops: {
      enabled: true,
      maxDryStreak: 15,
      guaranteedDrop: 'drop.leukocyte_pack',
      resetOnDrop: [
        'drop.leukocyte_pack',
        'drop.health',
      ],
      condition: 'player_health_below_50',
      description: 'Guarantees health when player < 50% HP after 15 kills',
    },
    powerup_drops: {
      enabled: true,
      maxDryStreak: {
        level1: 120,
        level2: 100,
        level3: 80,
      },
      guaranteedCategories: [
        {
          category: 'damage_boost',
          weight: 40,
          items: [
            'powerup.damage_boost',
            'powerup.piercing_arrows',
          ],
        },
        {
          category: 'utility',
          weight: 35,
          items: [
            'powerup.shield',
            'powerup.metabolic_haste',
          ],
        },
        {
          category: 'special',
          weight: 25,
          items: [
            'powerup.flamethrower',
            'powerup.chemo_reservoir',
          ],
        },
      ],
      description: "Ensures power-up progression doesn't stall",
    },
    elite_spawns: {
      enabled: true,
      maxDryStreak: 180000,
      guaranteedSpawn: 'enemy.viral_swarm_alpha',
      resetOnSpawn: [
        'elite',
        'unique',
        'boss',
      ],
      description: 'Forces elite spawn if none appear for 3+ minutes',
    },
    unique_spawns: {
      enabled: true,
      maxDryStreak: {
        level1: 300000,
        level2: 240000,
        level3: 180000,
      },
      guaranteedPool: {
        level1: [
          'unique.necrocyte_sentinel',
          'unique.phage_overlord',
        ],
        level2: [
          'unique.mutagen_splicer',
          'unique.chromoblast',
          'unique.necrocyte_sentinel',
        ],
        level3: [
          'unique.radiomorph_titan',
          'unique.cytokine_warcaller',
          'unique.psionic_leukocyte',
        ],
      },
      description: 'Ensures players experience unique enemies each run',
    },
    special_drops: {
      enabled: true,
      maxDryStreak: 200,
      guaranteedDrop: 'drop.metotrexat',
      resetOnDrop: [
        'drop.metotrexat',
        'drop.protein_cache',
        'drop.adrenal_surge',
      ],
      description: 'Guarantees special drop (Metotrexat) to prevent frustration',
    },
  },
  persistence: {
    trackAcrossLevels: false,
    trackAcrossRuns: false,
    saveToLocalStorage: true,
    debugMode: false,
  },
  balance: {
    pityDropQuality: {
      xp_drops: 1,
      health_drops: 1.2,
      powerup_drops: 1,
      special_drops: 1,
    },
    cooldowns: {
      samePityType: 30000,
      anyPityType: 10000,
    },
  },
  lootTableIntegration: {
    overrideNormalRolls: true,
    stackWithLootModifiers: true,
    respectedByElites: false,
    respectedByBosses: false,
  },
  display: {
    key: 'system.pity.name',
    descKey: 'system.pity.desc',
    category: 'system',
    tags: [
      'system',
      'balance',
      'pity',
      'rng',
      'progression',
    ],
  },
}
