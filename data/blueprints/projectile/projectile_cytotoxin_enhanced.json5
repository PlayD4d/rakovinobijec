{
  // Enhanced cytotoxin projectile for elite enemies
  id: 'projectile.cytotoxin_enhanced',
  type: 'projectile',
  
  // Enhanced stats (unified format)
  stats: {
    damage: 12,           // Higher damage than basic
    speed: 320,           // Faster than regular
    range: 900,           // Longer range
    size: 10,             // Larger projectile
    pierce: 0,            // No piercing
    lifetime: 3.0,        // Longer lifespan
    critChance: 0.15,     // 15% crit chance
    critMultiplier: 2.0,  // 2x damage on crit
  },
  
  // Graphics configuration for shape rendering
  graphics: {
    shape: 'star',        // Star shape for enhanced projectiles
    tint: 0xFF9800,       // Orange color
    size: 10,             // Size in pixels
    scale: 1.2
  },
  
  // Enhanced mechanics
  mechanics: {
    onHit: 'none',
    pierceDecay: 0,
    trail: {
      enabled: true,
      vfx: 'vfx.trail.toxic_enhanced',
      fadeTime: 400,
    },
    homing: true,         // Light homing ability
    homingStrength: 0.5,  // Moderate tracking
    bounce: false,
    // DOT effect
    dot: {
      enabled: true,
      damage: 2,          // 2 damage per tick
      duration: 3000,     // 3 seconds
      tickInterval: 500,  // Every 0.5 seconds
    }
  },
  
  // VFX effects
  vfx: {
    spawn: 'vfx.muzzle.enhanced',
    trail: 'vfx.trail.toxic_enhanced',
    hit: 'vfx.hit.toxic_enhanced',
    expire: 'vfx.projectile.fade',
  },
  
  // SFX sounds
  sfx: {
    spawn: 'sfx.weapon.fire.enhanced',
    hit: 'sfx.weapon.hit.enhanced',
    expire: 'sfx.projectile.fade',
  },
  
  // Display info
  display: {
    key: 'projectile.cytotoxin_enhanced.name',
    descKey: 'projectile.cytotoxin_enhanced.desc',
    templates: {
      short: '{{stats.damage}} DMG • {{stats.speed}} px/s • Homing',
      desc: 'Vylepšený cytotoxický projektil s {{stats.damage}} poškozením, naváděním a DOT efektem.',
    },
    color: '#FF9800',
    rarity: 'elite',
    icon: 'projectile.cytotoxin_enhanced',
    category: 'projectile',
    sortOrder: 120,
    tags: [
