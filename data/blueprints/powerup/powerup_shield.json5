{
  id: 'powerup.shield',
  type: 'powerup',
  stats: {
    maxLevel: 5,
  },
  mechanics: {
    modifiersPerLevel: [
      { 
        path: 'shieldHP', 
        type: 'base',  // PR7: Base value that gets set to (baseValue * level)
        value: 50,     // 50 HP per level (50, 100, 150, 200, 250)
        description: 'Shield HP increases by 50 per level'
      }
    ],
    stackable: false,  // Shield doesn't stack, only upgrades
    persistent: true,
    applyOnPickup: true,
    effectType: 'shield',
  },
  ability: {
    type: 'shield',
    baseShieldHP: 25,  // Base HP value for calculations
    rechargeTimePerLevel: [15000, 13000, 11000, 9000, 7000],  // 15s, 13s, 11s, 9s, 7s
  },
  vfx: {
    pickup: 'vfx.pickup',
    levelUp: 'vfx.powerup',
    hit: 'vfx.hit.small',
  },
  sfx: {
    pickup: 'sound/pickup.mp3',
    apply: 'sound/powerup.mp3',
    levelUp: 'sound/powerup.mp3',
    hit: 'sound/player_hit.mp3',
  },
  display: {
    key: 'powerup.shield.name',
    descKey: 'powerup.shield.desc',
    devNameFallback: '🛡️ Imunitní štít',
    devDescFallback: 'Poskytuje regenerující se štít',
    icon: 'powerup_shield',
    color: '#607D8B',
    rarity: 'rare',
    category: 'defense',
    sortOrder: 280,
    tags: [
      'powerup',
      'shield',
      'defense',
      'ability',
    ],
    templates: {
      short: '{{mechanics.modifiersPerLevel.{{level-1}}.value}} HP štít ({{ability.rechargeTimePerLevel.{{level-1}}}}ms regenerace)',
      long: 'Poskytuje regenerující se štít s {{mechanics.modifiersPerLevel.{{level-1}}.value}} HP. Regenerace po {{ability.rechargeTimePerLevel.{{level-1}}}}ms. Maximum level {{stats.maxLevel}}.',
    },
    srKey: 'sr.powerup.shield',
  },
}
