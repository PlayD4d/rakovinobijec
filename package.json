{
  "name": "rakovinobijec",
  "version": "0.5.87",
  "description": "Arcade-style top-down shooter hra pro podporu v boji proti rakovině",
  "main": "index.html",
  "scripts": {
    "dev": "python3 -u scripts/dev-server.py",
    "serve": "python3 -m http.server 8000",
    "serve-alt": "npx serve .",
    "version": "echo $npm_package_version",
    "changelog": "echo 'Changelog updated'",
    "audit:data": "node scripts/enhanced-data-audit.mjs",
    "audit:data:strict": "node scripts/enhanced-data-audit.mjs --strict-i18n",
    "audit:report": "node scripts/enhanced-data-audit.mjs --report-md",
    "fix:i18n": "node scripts/fix-i18n.mjs",
    "balance:test": "node scripts/balance-smoke.mjs",
    "smoke:test": "node scripts/smoke-run.mjs",
    "verify:all": "npm run audit:data:strict && npm run smoke:test",
    "analyze:session": "node scripts/analyze-session.mjs",
    "analyze:session:full": "node scripts/analyze-session.mjs --full",
    "analyze:telemetry": "node scripts/analyze-telemetry.mjs --mode=session",
    "analyze:pattern": "node scripts/analyze-telemetry.mjs --mode=pattern",
    "analyze:latest": "node scripts/analyze-telemetry.mjs --mode=latest",
    "analyze:aggregate": "node scripts/analyze-telemetry.mjs --mode=pattern --aggregate",
    "analyze:verbose": "node scripts/analyze-telemetry.mjs --mode=latest --verbose --html",
    "compare:runs": "node scripts/compare-telemetry.mjs",
    "validate:telemetry": "node scripts/validate-telemetry-analyzer.mjs",
    "rebuild:index": "node scripts/rebuild-registry-index.mjs",
    "postinstall": "simple-git-hooks",
    "guard:check": "bash dev/refactor/check_guards.sh",
    "guard:check-all": "bash dev/refactor/check_all_guards.sh",
    "guard:phaser": "bash dev/refactor/check_phaser_api.sh",
    "test:golden-path": "node scripts/golden-path-test.mjs",
    "test:leak": "node scripts/leak-test.mjs",
    "validate:blueprints": "node scripts/validate-all-blueprints.mjs",
    "ci:full": "node scripts/ci-full.mjs",
    "ci:full:verbose": "node scripts/ci-full.mjs --verbose",
    "ci:quick": "npm run guard:check && npm run smoke:test",
    "check:orphans": "node scripts/check-orphans.mjs",
    "generate:audio": "node scripts/generate-audio-manifest.mjs",
    "prebuild": "npm run generate:audio",
    "test:automated": "node scripts/automated-gameplay-test.mjs",
    "test:automated:core": "node scripts/automated-gameplay-test.mjs -s CoreGameplay",
    "test:automated:verbose": "node scripts/automated-gameplay-test.mjs -v"
  },
  "keywords": [
    "game",
    "phaser",
    "javascript",
    "healthcare",
    "arcade",
    "shooter"
  ],
  "author": {
    "name": "PlayD4d",
    "email": "playd4d.me@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PlayD4d/rakovinobijec.git"
  },
  "homepage": "https://playd4d.github.io/rakovinobijec/",
  "dependencies": {
    "ajv": "^8.17.1",
    "glob": "^13.0.6",
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "simple-git-hooks": "^2.9.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run audit:data"
  }
}
